# Large binaries & data tracked via Git LFS
*.xlsx filter=lfs diff=lfs merge=lfs -text
*.xlsm filter=lfs diff=lfs merge=lfs -text
*.pdf  filter=lfs diff=lfs merge=lfs -text
*.tsv  filter=lfs diff=lfs merge=lfs -text
*.csv  filter=lfs diff=lfs merge=lfs -text
*.pkl  filter=lfs diff=lfs merge=lfs -text

# EXCEPTION: the governed reference tables are small, human-editable text — keep
# them OUT of LFS so they diff and render on GitHub.
reference/list_catalog.csv   !filter !diff !merge text
reference/term_lists.csv     !filter !diff !merge text
reference/term_mappings.csv  !filter !diff !merge text
